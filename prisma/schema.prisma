// Prisma 스키마 - reCree MVP
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  USER
  EDITOR
  ADMIN
}

enum PostStatus {
  DRAFT       // 임시저장 (편집 중)
  PUBLISHED   // 사용자에게 노출
}

enum PlaceSource {
  ADMIN
  USER
}

enum PlaceStatus {
  OPEN
  CLOSED_TEMP
  CLOSED_PERMANENT
}

enum ReCreeshotStatus {
  ACTIVE
  REPORTED
  HIDDEN
  DELETED
}

enum ImageType {
  BANNER    // 장소 사진 (캐러셀, 최대 5장)
  ORIGINAL  // 연예인 원본 장면/사진 (배너 좌하단 오버레이, 최대 2장)
}

enum ImageSource {
  UPLOAD  // Supabase Storage 직접 업로드
  URL     // 외부 이미지 URL 직접 입력
  AUTO    // 출처 URL에서 자동 추출 (YouTube oembed 썸네일 등)
}

enum SourceType {
  PRIMARY    // 공식 출처 (공식 유튜브, 공식 인스타, 기사 등)
  REFERENCE  // 참고 출처 (팬 트위터, 팬 인스타, 블로그 등)
}

enum SaveTarget {
  POST
  RECREESHOT
}

enum SectionType {
  MANUAL
  AUTO_NEW
  AUTO_HOT
}

enum ContentType {
  POST
  RECREESHOT
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id              String   @id @db.Uuid
  email           String   @unique
  nickname        String?
  bio             String?
  profileImageUrl String?
  role            UserRole @default(USER)
  language        String   @default("en")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  posts       Post[]
  reCreeshots ReCreeshot[]
  saves       Save[]
}

model Topic {
  id        String    @id @default(uuid()) @db.Uuid
  nameKo    String
  nameEn    String
  slug      String    @unique
  level     Int       @default(0)
  parentId  String?   @db.Uuid
  colorHex     String?
  colorHex2    String?   // 그라데이션 끝 색 (null = 단색)
  gradientDir  String    @default("to bottom")  // 그라데이션 방향
  gradientStop Int       @default(150)           // 그라데이션 종료 위치 (%)
  textColorHex String?
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  parent   Topic?  @relation("TopicHierarchy", fields: [parentId], references: [id])
  children Topic[] @relation("TopicHierarchy")

  postTopics        PostTopic[]
  reCreeshotTopics  ReCreeshotTopic[]
  curatedSections   CuratedSection[]  @relation("FilterTopic")
}

model Tag {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  nameKo    String
  slug      String   @unique
  group     String
  colorHex     String?   // null = 그룹 색 상속
  colorHex2    String?   // 그라데이션 끝 색 (null = 단색)
  textColorHex String?   // null = 그룹 색 상속
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  postTags        PostTag[]
  reCreeshotTags  ReCreeshotTag[]
  curatedSections CuratedSection[] @relation("FilterTag")
}

model TagGroupConfig {
  group        String   @id
  nameEn       String   @default("")
  colorHex     String   @default("#C6FD09")
  colorHex2    String?
  gradientDir  String   @default("to bottom")
  gradientStop Int      @default(150)
  textColorHex String   @default("#000000")
  sortOrder    Int      @default(0)
  updatedAt    DateTime @updatedAt
}

model Post {
  id           String     @id @default(uuid()) @db.Uuid
  titleKo      String
  titleEn      String
  slug         String     @unique
  bodyKo       String?
  bodyEn       String?
  status       PostStatus @default(DRAFT)
  source       String?
  importNote   String?    // 시트 원본 데이터 (JSON 문자열)
  memo         String?    // 관리자 내부 메모
  collectedBy  String?    // 수집자 이름
  collectedAt  String?    // 수집 날짜 (예: "2024-01-15")
  viewCount    Int        @default(0)
  saveCount    Int        @default(0)
  authorId     String?    @db.Uuid
  translatedAt DateTime?
  publishedAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  author      User?        @relation(fields: [authorId], references: [id])
  postTopics  PostTopic[]
  postTags    PostTag[]
  postPlaces  PostPlace[]
  postImages  PostImage[]
  postSources PostSource[]
  homeBanners HomeBanner[]
}

model PostImage {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  postId      String      @db.Uuid
  imageType   ImageType
  imageSource ImageSource @default(UPLOAD)
  url         String
  linkUrl     String?     // 카드 클릭 시 이동 URL (ORIGINAL 이미지용)
  isThumbnail Boolean     @default(false)
  sortOrder   Int         @default(0)
  slotIndex   Int?        // null=BANNER, 0=슬롯1, 1=슬롯2
  isSlotCard  Boolean     @default(false)  // 슬롯별 미니 소스 카드 대표 이미지
  focalX      Float?      // 0.0 ~ 1.0, null = 0.5 (center)
  focalY      Float?      // 0.0 ~ 1.0, null = 0.5 (center)
  createdAt   DateTime    @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

model PostSource {
  id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  postId         String     @db.Uuid
  url            String
  sourceType     SourceType @default(PRIMARY)
  platform       String?    // YOUTUBE | X | INSTAGRAM | PINTEREST | BLOG | ARTICLE | OTHER
  sourceNote     String?
  sourcePostDate String?    // 출처 원본 게시 날짜 (예: "2024-01-15")
  isOriginalLink Boolean    @default(false) // 원본이미지 클릭 시 이동 URL (포스트당 1개만 true)
  sortOrder      Int        @default(0)
  createdAt      DateTime   @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

model Place {
  id             String      @id @default(uuid()) @db.Uuid
  nameKo         String
  nameEn         String?
  addressKo      String?
  addressEn      String?
  latitude       Float?
  longitude      Float?
  googlePlaceId  String?     @unique
  googleMapsUrl  String?
  naverPlaceId   String?
  naverMapsUrl   String?
  kakaoMapsUrl   String?
  gettingThere   String?    // 교통편 안내 텍스트
  placeTypes     String[]   @default([])  // 장소 유형 (예: ["카페", "포토스팟"])
  phone          String?
  operatingHours Json?
  rating         Float?    // Google Maps 평점
  imageUrl       String?
  source         PlaceSource @default(ADMIN)
  isVerified     Boolean     @default(false)
  status         PlaceStatus @default(OPEN)
  country        String      @default("KR")
  city           String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  postPlaces   PostPlace[]
  reCreeshots  ReCreeshot[]
}

model ReCreeshot {
  id               String           @id @default(uuid()) @db.Uuid
  userId           String           @db.Uuid
  placeId          String?          @db.Uuid
  linkedPostId     String?          @db.Uuid
  imageUrl         String
  referencePhotoUrl String?
  story            String?
  tips             String?
  locationName     String?
  locationLat      Float?
  locationLng      Float?
  matchScore       Float?
  showBadge        Boolean          @default(false)
  status           ReCreeshotStatus @default(ACTIVE)
  saveCount        Int              @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user            User              @relation(fields: [userId], references: [id])
  place           Place?            @relation(fields: [placeId], references: [id])
  reCreeshotTopics ReCreeshotTopic[]
  reCreeshotTags   ReCreeshotTag[]
}

// ─── M:N 조인 테이블 ──────────────────────────────────────────────────────────

model PostTopic {
  postId       String   @db.Uuid
  topicId      String   @db.Uuid
  isVisible    Boolean  @default(false)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())

  post  Post  @relation(fields: [postId], references: [id], onDelete: Cascade)
  topic Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@id([postId, topicId])
}

model PostTag {
  postId       String   @db.Uuid
  tagId        String   @db.Uuid
  isVisible    Boolean  @default(false)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
}

model PostPlace {
  postId      String   @db.Uuid
  placeId     String   @db.Uuid
  context     String?
  vibe        String[]
  mustTry     String?
  tip         String?
  insightEn   Json?
  createdAt   DateTime @default(now())

  post  Post  @relation(fields: [postId], references: [id], onDelete: Cascade)
  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@id([postId, placeId])
}

model ReCreeshotTopic {
  reCreeshotId String   @db.Uuid
  topicId      String   @db.Uuid
  createdAt    DateTime @default(now())

  reCreeshot ReCreeshot @relation(fields: [reCreeshotId], references: [id], onDelete: Cascade)
  topic      Topic      @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@id([reCreeshotId, topicId])
}

model ReCreeshotTag {
  reCreeshotId String   @db.Uuid
  tagId        String   @db.Uuid
  createdAt    DateTime @default(now())

  reCreeshot ReCreeshot @relation(fields: [reCreeshotId], references: [id], onDelete: Cascade)
  tag        Tag        @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([reCreeshotId, tagId])
}

// ─── 기타 모델 ────────────────────────────────────────────────────────────────

model Save {
  id         String     @id @default(uuid()) @db.Uuid
  userId     String     @db.Uuid
  targetType SaveTarget
  targetId   String     @db.Uuid
  createdAt  DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetType, targetId])
}

model HomeBanner {
  id             String  @id @default(uuid()) @db.Uuid
  postId         String  @db.Uuid
  order          Int     @default(0)
  isActive       Boolean @default(true)
  labelOverrides Json?   // [{ type: "topic"|"tag", id: string }] 최대 3개. null = 기본(isVisible top-2)

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model CuratedSection {
  id            String      @id @default(uuid()) @db.Uuid
  titleEn       String
  subtitleEn    String?
  contentType   ContentType @default(POST)
  type          SectionType @default(MANUAL)
  postIds       String[]    @db.Uuid
  filterTopicId String?     @db.Uuid
  filterTagId   String?     @db.Uuid
  maxCount      Int         @default(10)
  order         Int         @default(0)
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  filterTopic Topic? @relation("FilterTopic", fields: [filterTopicId], references: [id])
  filterTag   Tag?   @relation("FilterTag", fields: [filterTagId], references: [id])
}

model PopularSearch {
  id        String   @id @default(uuid()) @db.Uuid
  keyword   String   @unique
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
